# backend/.env example
DATABASE_URL=mysql+pymysql://construction_user:your_password@localhost:3306/construction_db

# Arduino
ARDUINO_PORT=COM3
ARDUINO_BAUDRATE=9600

# OpenAI (Whisper STT)
OPENAI_API_KEY=sk-...
OPENAI_STT_MODEL=whisper-1

# Google Gemini (text + vision analysis)
GEMINI_API_KEY=AIza...
# Optional: comma-separated fallback list
GEMINI_TEXT_MODELS=gemini-2.0-flash,gemini-1.5-flash
GEMINI_VISION_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Upload directory (relative to backend)
UPLOAD_DIR=../uploads
