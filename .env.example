# Optional. Leave empty to use local SQLite automatically.
DATABASE_URL=

# Arduino
ARDUINO_PORT=COM3
ARDUINO_BAUDRATE=9600
ENABLE_ARDUINO=0

# Auth bootstrap
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin1234!
AUTH_SESSION_HOURS=24

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_TEXT_MODELS=gemini-2.0-flash,gemini-1.5-flash
GEMINI_VISION_MODELS=gemini-2.0-flash,gemini-1.5-flash

# YOLO (optional)
ENABLE_YOLO=1
YOLO_MODEL_PATH=
YOLO_MODEL_GLOBS=

# Upload directory
UPLOAD_DIR=./uploads

